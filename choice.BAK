	endif	
 retu

 PROCE SELECUST
	STORE 0 TO holdkey,m.mn_code
	STORE SPACE(24) TO mcity
	STORE SPACE(2) TO mstate
	STORE SPACE(10) TO mzip
	D=0
	STORE SPACE(40) TO mc_name2,mc_name1,m.c_name
	use selemenu
	set order to tag shd_name
	DIME carr1(40,1)
	FOR i= 1 TO 40
		STORE SPACE(1) TO carr1(i,1)
	ENDFOR
*** Mouse click and keyboard detection example ***
*** Establish the program environment ***
	SET TALK OFF
	SET ESCAPE OFF
*** Create and open a window ***
	i=10
	j=48
	D=0
	C=1
	P=5.800
	DO adisp
	DO WHILE .T.
		IF CAPSLOCK()=.F.
			=CAPSLOCK(!CAPSLOCK( ))
		ENDIF
		inval1 = INKEY()	&& Get INKEY( ), hide cursor, checkmouse
		IF inval1 = 0	    && No key or mouse press
			LOOP
		ENDIF
		IF inval1=27
			Clea
			RETU
		ENDIF
		IF inval1 = 13	   && Escape key pressed, exit main loop
			SET FILTER TO
			m.c_name=SPACE(40)
			mc_name1=SPACE(40)
			FOR t= 1 TO C
				mc_name1=mc_name1+carr1(t,1)
			ENDFOR
			SET FILTER TO
			SET FILTER TO ALLTRIM(SUBSTR(shd_name,1,LEN(ALLTRIM(mc_name1))))=ALLTRIM(mc_name1) 
			GO TOP
			m.c_name=shd_name
			m.mn_code=mn_code
			m.prgname=prgname
			EXIT
		ENDIF
		IF inval1=5 OR inval1=24
			mc_name2=SPACE(40)
			FOR a= 1 TO 40
				mc_name2=mc_name2+carr1(a,1)
			ENDFOR
			SET FILTER TO
			SET FILTER TO ALLTRIM(SUBSTR(shd_name,1,LEN(ALLTRIM(mc_name2))))=ALLTRIM(mc_name2)
			COUNT TO nrec
			IF nrec=0
				SET FILTER TO
			ENDIF
			SET ORDER TO TAG shd_name
	DEFINE POPUP cust FROM 8,40 TO 25,75 PROMP FIELD shd_name
ON SELE POPUP cust DO Centry1
Acti POPUP cust
IF m.c_name#'   '
	EXIT
ENDIF
ENDIF
IF (inval1)>=32 AND (inval1)<=126
	mc_name1=' '
	carr1(C,1)=CHR(inval1)
	FOR t= 1 TO C
		mc_name1=mc_name1+carr1(t,1)
	ENDFOR
	SET FILTER TO
	SET FILTER TO ALLTRIM(SUBSTR(shd_name,1,LEN(ALLTRIM(mc_name1))))=ALLTRIM(mc_name1) 
	GO TOP
	COUNT TO nrec
	IF nrec=0
		SET FILTER TO
		mc_name=SPACE(40)
		IF C-1#0
			carr1(C,1)=SPAC(1)
			FOR t= 1 TO C
				mc_name2=mc_name2+carr1(t,1)
			ENDFOR
			@P,j SAY ALLTRIM(mc_name2)
*				C=C-1
*				I=I-1
			LOOP
		ENDIF
	ELSE
		IF C<40
			mc_name2=SPACE(40)
			@P,j SAY mc_name2
			FOR t= 1 TO C
				mc_name2=ALLTRIM(mc_name2)+SPACE(1)
			ENDFOR
			a=j
			FOR t= 1 TO C
				mc_name2=mc_name2+carr1(t,1)
			ENDFOR
			@P,j SAY mc_name2
			i=i+1
			C=C+1
		ENDIF
	ENDIF
ENDIF
DO CASE
CASE inval1=127
	FOR a= C TO 40
		carr1(a,1)=SPACE(1)
	ENDFOR
	mc_name2=SPACE(40)
	IF C-1#0
		carr1(C-1,1)=SPAC(1)
		@P,j SAY mc_name2
		FOR t= 1 TO C
			mc_name2=mc_name2+carr1(t,1)
		ENDFOR
		@P,j SAY ALLTRIM(mc_name2)
		C=C-1
		i=i-1
	ENDIF
	DO adisp
	LOOP
ENDCASE
DO adisp
Hide POPUP cust
*	A=1
*	B=j
*	FOR A=1 TO C-1
*		@7,B SAY carr1(A,1)
*		B=B+1
*	ENDFOR
ENDDO
FOR a= 1 TO C
	mc_name2=mc_name2+carr1(a,1)
ENDFOR
mc_name2=shd_name
Clea
RETU	

	PROCE Centry1
	m.c_name=SPACE(40)
	m.c_name=shd_name
	m.mn_code=mn_code
	m.prgname=prgname
	Hide POPUP cust
	Deac POPUP cust
	RETU

	PROC adisp
	mc_name1=SPACE(40)
	FOR t= 1 TO C
		mc_name1=mc_name1+carr1(t,1)
	ENDFOR
	SET FILTER TO
	SET FILTER TO ALLTRIM(SUBSTR(shd_name,1,LEN(ALLTRIM(mc_name1))))=ALLTRIM(mc_name1) 
	GO TOP
	COUNT TO nrec
	IF nrec=0
		SET FILTER TO
	ENDIF
	SET ORDER TO TAG shd_name
	DEFINE POPUP cust FROM 8,40 TO 25,75 PROMP FIELD shd_name
	ON SELE POPUP cust DO entRy1
	Show POPUP cust
	Hide POPUP cust
	
	
Proc todaydt
sele a
use stp
sele b
use today
PRIVATE prnt_btn,p_recs,p_output,pr_out,pr_record,voucher
STORE 1 TO p_recs,p_output
STORE 0 TO prnt_btn,m.a_code,m.tax_amt,m.tvalue,msno,m.r_output,m.shd_code
m.p_output=2

m.pr_out=IIF(m.p_output=1,'TO PRINT PROMPT NOCONSOLE','PREVIEW')
REPO FORM todaydt &pr_out for d_code=a->D_code
clos all
retu
