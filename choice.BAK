proce ajohn
	DEFINE WINDOW _qjn12zb ;
	AT  0.000, 0.000  ;
	SIZE 27.462,86.600 ;
	FONT "MS Sans Serif", 8 ;
	STYLE "B" ;
	FLOAT ;
