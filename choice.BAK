		MESSAGE 'Close the software.'
	CLEA GETS	
	store 0 to m.mn_code
	m.prgname=space(8)
	prgnm=space(8)
	PK=SPACE(1)
	@5.800,40 SAY "Icon :" ;
			SIZE 1.000,5.667 ;
			FONT "MS Sans Serif", 8 ;
			STYLE "BT" ;
			PICTURE "@J" ;
